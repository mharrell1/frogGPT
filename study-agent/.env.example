# ─────────────────────────────────────────────────────────────────────────────
# Study Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# The agent supports two auth modes — choose ONE:

# ── Option A: Google AI Studio (no GCP billing required) ─────────────────────
# Get a free API key at: https://aishudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=False

# ── Option B: Vertex AI (requires GCP project with billing) ──────────────────
# Uncomment and fill in these, then comment out the lines above.
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
